# =============================================================
# WARNING: Never commit this file with real values.
# Canonical credential source: Infisical at https://infisical.petersimmons.com
# Run 'make init' to generate POSTGRES_PASSWORD and ENGRAM_API_KEY locally.
# =============================================================
#
# Environment Variable Namespace Convention:
# - ENGRAM_*         → Engram server config and feature flags
# - LITELLM_*        → LiteLLM proxy config (when using hybrid profile)
# - ANTHROPIC_*      → Claude API key (optional, enables AI-enhanced tools)
# - POSTGRES_*       → PostgreSQL credentials
# - DATABASE_URL     → Full PostgreSQL connection string (computed from POSTGRES_*)
# - OLLAMA_*         → Ollama config (local profile only)
#
# Note: Multiple namespaces are intentional. Each reflects the service boundary
# where that config is used. LITELLM_* vars go to the LiteLLM proxy, ENGRAM_*
# go to the Engram server, etc. This avoids prefix collisions and makes the data
# flow clear in container environment listings.
# =============================================================

# =============================================================
# Required
# =============================================================

# PostgreSQL password — generated by 'make init', must match Dockerfile.postgres
POSTGRES_PASSWORD=change_me_to_a_strong_password

# PostgreSQL connection string — generated by 'make init'
# DATABASE_URL=postgres://engram:<password>@localhost:5432/engram

# Bearer token for MCP authentication — generated by 'make init'
# ENGRAM_API_KEY=<64-char-hex-token>

# =============================================================
# Optional: server config
# =============================================================

# Port the MCP SSE server listens on (default: 8788)
# ENGRAM_PORT=8788

# Bind address (default: 0.0.0.0; use 127.0.0.1 to restrict to loopback)
# ENGRAM_HOST=0.0.0.0

# External URL advertised in SSE events — set this when behind a reverse proxy
# or when the bind address is 0.0.0.0 so clients forward auth to the right host
# (default: http://<host>:<port>)
# ENGRAM_BASE_URL=http://127.0.0.1:8788

# Base directory for file operations — required when using export/ingest tools
# ENGRAM_DATA_DIR=

# Allow /setup-token from RFC1918 Docker bridge IPs (required for Docker setups)
# (default: false)
# ENGRAM_SETUP_TOKEN_ALLOW_RFC1918=false

# Trust X-Forwarded-For and X-Real-IP headers from a reverse proxy
# Only enable if a trusted L7 proxy terminates all inbound connections
# (default: false)
# ENGRAM_TRUST_PROXY_HEADERS=false

# HTTP rate limiter configuration (#387)
# Per-IP sustained request rate in req/s (default: 50)
# ENGRAM_RATE_LIMIT_RPS=50

# Per-IP token-bucket burst size (default: 200)
# ENGRAM_RATE_LIMIT_BURST=200

# Disable HTTP rate limiting entirely — recommended for single-user local machines
# where bulk writes and setup-token hammering would otherwise cause 429s.
# Loopback IPs (127.0.0.1, ::1) are always exempt regardless of this setting.
# (default: false)
# ENGRAM_RATE_LIMIT_DISABLE=false

# =============================================================
# Optional: Ollama embedding and summarization
# =============================================================

# Ollama base URL (default: http://ollama:11434 — Ollama inside Docker)
# Use http://host.docker.internal:11434 for native Ollama outside Docker (Mac)
# OLLAMA_URL=http://ollama:11434

# Embedding model (default: nomic-embed-text)
# ENGRAM_OLLAMA_MODEL=nomic-embed-text

# Summarization model used by background summarizer (default: llama3.2)
# ENGRAM_SUMMARIZE_MODEL=llama3.2

# Enable background summarization worker (default: true)
# ENGRAM_SUMMARIZE_ENABLED=true

# =============================================================
# Optional: Claude advisor
# =============================================================

# Anthropic API key — enables memory_reason, memory_explore, memory_ask,
# memory_query_document, and optionally Claude-backed summarization,
# consolidation, re-ranking, and entity extraction
# ANTHROPIC_API_KEY=

# Use Claude for background summarization instead of Ollama (default: false)
# ENGRAM_CLAUDE_SUMMARIZE=false

# Use Claude for near-duplicate merge during consolidation (default: false)
# ENGRAM_CLAUDE_CONSOLIDATE=false

# Enable Claude re-ranking in memory recall (default: false)
# ENGRAM_CLAUDE_RERANK=false

# Comma-separated list of projects to run entity extraction on (default: empty)
# Requires ANTHROPIC_API_KEY to be set
# ENGRAM_ENTITY_PROJECTS=

# =============================================================
# Advanced tuning
# =============================================================

# Default recall detail mode: handle | full (default: handle)
# handle = lightweight references, fetch only what you need
# full   = return complete memory objects on every recall
# ENGRAM_RECALL_DEFAULT_MODE=handle

# Maximum results returned by memory_recall — hard cap applied after scoring (default: 500)
# ENGRAM_RECALL_MAX_TOP_K=500

# GlobalReembedder: chunks to embed per polling iteration (default: 100)
# ENGRAM_REEMBED_BATCH_SIZE=100

# GlobalReembedder: delay between polling iterations (default: 10s)
# ENGRAM_REEMBED_INTERVAL=10s

# Maximum bytes returned by memory_fetch with detail=full (default: 65536)
# ENGRAM_FETCH_MAX_BYTES=65536

# Maximum iterations for memory_explore iterative synthesis loop (default: 5)
# ENGRAM_EXPLORE_MAX_ITERS=5

# Maximum parallel workers for memory_explore (default: 8)
# ENGRAM_EXPLORE_MAX_WORKERS=8

# Token budget for memory_explore synthesis context (default: 20000)
# ENGRAM_EXPLORE_TOKEN_BUDGET=20000

# Maximum bytes for a memory stored via memory_store_document (default: 8388608 = 8 MB)
# ENGRAM_MAX_DOCUMENT_BYTES=8388608

# Maximum bytes for raw document blob storage (default: 52428800 = 50 MB)
# ENGRAM_RAW_DOCUMENT_MAX_BYTES=52428800

# Maximum tokens for RAG-style synthesis responses (default: 4096)
# ENGRAM_RAG_MAX_TOKENS=4096

# How often the importance decay worker runs (default: 8h; 0 = use default)
# ENGRAM_DECAY_INTERVAL=0

# How often the decay audit worker runs (default: 6h)
# ENGRAM_AUDIT_INTERVAL=6h

# How often the adaptive weight tuner runs (default: 24h)
# ENGRAM_WEIGHT_INTERVAL=24h

# Enable pprof profiling server on localhost:6060 (set to 1 to enable)
# ENGRAM_PPROF=

# PostgreSQL buffer tuning — defaults to 10% of RAM for shared_buffers.
# On a 125 GB host: 12 GB shared_buffers, 48 GB effective_cache_size.
# Adjust per machine; effective_cache_size should be ~4x shared_buffers.
PG_SHARED_BUFFERS=12GB
PG_EFFECTIVE_CACHE_SIZE=48GB
