  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__engram__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/engram hook PostToolUse",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 /home/psimmons/.claude/hooks/engram-denial-capture.py /home/psimmons/.claude/projects/-home-psimmons/memory/denial-log.md",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ruff-check.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/instinct-post-tool-use.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/telemetry-emit.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/no-silent-tool-failure.sh",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-checks.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/bin/engram hook Stop",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/telemetry-emit.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__engram__*",
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/engram hook PreToolUse",
            "timeout": 8,
            "statusMessage": "Checking Engram connectivity"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pytest-precommit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-readonly-bash.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/branch-write-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/secret-pattern-scanner.sh",
            "timeout": 8
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/bin/engram hook PreCompact",
            "timeout": 8,
            "statusMessage": "Storing session snapshot to engram before compaction"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-branch.sh",
            "timeout": 5,
            "statusMessage": "Recording session start branch"
          },
          {
            "type": "command",
            "command": "~/bin/engram hook SessionStart",
            "timeout": 60,
            "statusMessage": "Engram: auth + recall + flush"
          },
          {
            "type": "command",
            "command": "~/bin/generate-session-context.py",
            "timeout": 15,
            "statusMessage": "Generating session context"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/sync-armies-xp.sh",
            "timeout": 5,
            "statusMessage": "Syncing armies XP from local profiles"
          },
          {
            "type": "command",
            "command": "~/.armies/bin/sync-to-claude-agents.sh",
            "timeout": 8,
            "statusMessage": "Syncing armies profiles \u2192 ~/.claude/agents/"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/telemetry-emit.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "/home/psimmons/.claude/hooks/session-start-budget.sh",
            "timeout": 5,
            "statusMessage": "Checking CLAUDE.md line budget"
          }
        ]
      }
    ]
