# LiteLLM backend endpoints — copy to .env and fill in your values.
# Referenced in litellm_config.yaml via os.environ/VAR_NAME.
# No server names should appear in litellm_config.yaml itself.

# W6800 — Ollama on precision host
PRECISION_OLLAMA_URL=http://precision.petersimmons.com:11434

# MI50 — llama-server on precision host (llama.cpp, OpenAI-compatible)
PRECISION_LLAMACPP_URL=http://precision.petersimmons.com:11435

# RX 7900 XT — Ollama on leviathan (real DNS, reachable from K8s and external services)
LEVIATHAN_OLLAMA_URL=http://leviathan.petersimmons.com:11434
