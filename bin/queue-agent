#!/usr/bin/env bash
set -euo pipefail

OWNER="${GITHUB_OWNER:-petersimmons1972}"
# Fallback list used only if the authoritative config below is unreachable.
FALLBACK_REPOS="engram-go olla aifleet factvault agent-gateway instinct harness-port yourai codex"
# Authoritative target-repo list. Single source of truth shared with the
# codex-poll poller: petersimmons1972/claude-codex:config/target-repos.txt,
# cached locally at ~/.cache/claude-codex. Entries are full owner/name slugs,
# one per line, with `#` comments. We strip the "<owner>/" prefix to get the
# short repo name this script accepts.
TARGET_REPOS_FILE="${CLAUDE_CODEX_CACHE:-$HOME/.cache/claude-codex}/config/target-repos.txt"

VALID_AGENTS="codex hermes"

# Derive VALID_REPOS from the shared config file; fall back if unreadable.
if [[ -r "$TARGET_REPOS_FILE" ]]; then
  VALID_REPOS="$(
    sed -e 's/#.*$//' "$TARGET_REPOS_FILE" \
      | awk '{ $1=$1; print }' \
      | sed -e 's@^[^/]*/@@' \
      | grep -v '^$' \
      | tr '\n' ' '
  )"
  # Guard against an empty/garbled file: never end up with no valid repos.
  [[ -n "${VALID_REPOS// }" ]] || VALID_REPOS="$FALLBACK_REPOS"
else
  VALID_REPOS="$FALLBACK_REPOS"
fi

agent=""
repo=""
title=""
brief=""
priority="p2"
target_repo=""
extra_labels=()

base="$(basename "$0")"
if [[ "$base" == "queue-codex" ]]; then
  echo "queue-codex is deprecated; use queue-agent --agent codex" >&2
  agent="codex"
fi

usage() {
  cat <<'EOF'
Usage: queue-agent --agent <codex|hermes> --repo <name> --title "..." --brief brief.md [--priority p2] [--label bug]
EOF
}

fail() {
  echo "queue-agent: $*" >&2
  exit 2
}

contains_word() {
  local needle="$1"; shift
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

section_nonempty() {
  local section="$1" file="$2"
  awk -v section="$section" '
    $0 == section { in_section=1; next }
    /^## / && in_section { exit found ? 0 : 1 }
    in_section && $0 !~ /^[[:space:]]*$/ { found=1 }
    END { if (in_section && found) exit 0; exit 1 }
  ' "$file"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --agent) agent="${2:-}"; shift 2 ;;
    --repo) repo="${2:-}"; shift 2 ;;
    --title) title="${2:-}"; shift 2 ;;
    --brief) brief="${2:-}"; shift 2 ;;
    --priority) priority="${2:-}"; shift 2 ;;
    --target-repo) target_repo="${2:-}"; shift 2 ;;
    --label) extra_labels+=("${2:-}"); shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) fail "unknown argument: $1" ;;
  esac
done

[[ -n "$agent" ]] || fail "--agent is required"
[[ "$agent" != *","* ]] || fail "--agent accepts a single value in v1; comma-separated multi-agent routing is a v2 feature"
contains_word "$agent" $VALID_AGENTS || fail "--agent must be one of: $VALID_AGENTS"

[[ -n "$repo" ]] || fail "--repo is required"
contains_word "$repo" $VALID_REPOS || fail "--repo must be one of: $VALID_REPOS"
[[ -n "$title" ]] || fail "--title is required"
[[ -n "$brief" && -f "$brief" ]] || fail "--brief must point to a readable file"
[[ "$priority" =~ ^p[0-3]$ ]] || fail "--priority must be p0, p1, p2, or p3"
if [[ -n "$target_repo" && ! "$target_repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
  fail "--target-repo must be in owner/name format"
fi

for section in "## Files" "## Acceptance (TDD)" "## Spec refs" "## Constraints"; do
  section_nonempty "$section" "$brief" || fail "brief missing non-empty section: $section"
done

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

{
  if [[ -n "$target_repo" ]]; then
    printf 'Target-Repo: %s\n' "$target_repo"
  fi
  printf 'Filed by queue-agent on %s at the request of: %s\n\n' "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" "$(git config user.name 2>/dev/null || printf unknown)"
  cat "$brief"
} >"$tmp"

labels=(--label "agent/$agent" --label "agent/$agent/queued" --label "priority/$priority")
for label in "${extra_labels[@]}"; do
  [[ -n "$label" ]] && labels+=(--label "$label")
done

gh issue create \
  --repo "$OWNER/$repo" \
  --title "$title" \
  --body-file "$tmp" \
  "${labels[@]}"
