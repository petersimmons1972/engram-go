#!/usr/bin/env bash

set -euo pipefail
umask 077

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

QUEUE_LABEL="${CODEX_QUEUE_LABEL:-agent/codex/queued}"
WORKING_LABEL="${CODEX_WORKING_LABEL:-agent/codex/in-progress}"
HOLD_LABEL="${CODEX_HOLD_LABEL:-decision/needs-founder}"
DONE_LABEL="${CODEX_DONE_LABEL:-agent/codex/done}"
STALLED_LABEL="${CODEX_STALLED_LABEL:-agent/codex/stalled}"
BLOCKED_LABEL="${CODEX_BLOCKED_LABEL:-agent/codex/blocked}"
NEEDS_CLAUDE_LABEL="${CODEX_NEEDS_CLAUDE_LABEL:-agent/codex/needs-claude}"
NEEDS_INPUT_LABEL="${CODEX_NEEDS_INPUT_LABEL:-agent/codex/needs-input}"
# CI gate (#20): bounded wait for PR checks before marking done. 0 disables polling.
CI_WAIT_SECONDS="${CODEX_CI_WAIT_SECONDS:-300}"
CI_POLL_INTERVAL="${CODEX_CI_POLL_INTERVAL:-30}"
CODEX_POLL_INTERVAL_SECS="${CODEX_POLL_INTERVAL_SECS:-${CI_POLL_INTERVAL}}"
CODEX_LIVENESS_STALE_SECS="${CODEX_LIVENESS_STALE_SECS:-$(( 2 * CODEX_POLL_INTERVAL_SECS ))}"

CACHE_DIR="${CLAUDE_CODEX_CACHE:-${HOME}/.cache/claude-codex}"
LIVENESS_STATE_DIR="${CODEX_POLL_HEARTBEAT_STATE_DIR:-${XDG_CACHE_HOME:-${HOME}/.cache}/claude-codex/state}"
LIVENESS_HEARTBEAT_FILE="${CODEX_POLL_HEARTBEAT_FILE:-${LIVENESS_STATE_DIR}/heartbeat.json}"
LIVENESS_GENERATION_FILE="${CODEX_POLL_HEARTBEAT_GENERATION_FILE:-${LIVENESS_STATE_DIR}/heartbeat-generation.json}"
TARGET_REPOS_FILE="${CACHE_DIR}/config/target-repos.txt"
PROJECTS_ROOT="${PROJECTS_ROOT:-${HOME}/projects}"
WORKTREES_ROOT="${WORKTREES_ROOT:-${HOME}/projects/.codex-poll-worktrees}"
STATE_DIR="${CODEX_POLL_STATE_DIR:-${HOME}/.cache/codex-poll}"
EVENT_DIR="${CODEX_POLL_EVENT_DIR:-${HOME}/.claude/events}"
STRIKE_STATE_DIR="${CODEX_POLL_STRIKE_DIR:-${HOME}/.local/state/codex-poll/strikes}"
STRIKE_WINDOW_SECONDS="${CODEX_POLL_STRIKE_WINDOW_SECONDS:-259200}"
LOCK_FILE="${CODEX_POLL_LOCK_FILE:-${STATE_DIR}/lock}"
LOG_FILE="${CODEX_POLL_LOG_FILE:-${STATE_DIR}/poll.log}"
CODEX_CACHE_SHA_FILE="${CODEX_CACHE_SHA_FILE:-${SCRIPT_DIR}/claude-codex.sha}"
CODEX_CACHE_REPO_SHA="${CODEX_CACHE_REPO_SHA:-}"
STRIKE_TOOL="${CODEX_POLL_STRIKE_TOOL:-${HOME}/scripts/strikes.py}"

CODEX_BIN="${CODEX_BIN:-codex}"
HANDOFF_BIN="${HANDOFF_BIN:-${HOME}/bin/codex-handoff}"
REMOTE_NAME="${CODEX_REMOTE_NAME:-origin}"
TERMINAL_STATE_FILE="${CODEX_POLL_TERMINAL_STATE_FILE:-${STATE_DIR}/terminal-state.json}"

CLAIM_SKIP_REASON=""
CLAIM_BRIEF_ID=""
CLAIM_TARGET_REPO=""
CLAIM_TARGET_REPO_PATH=""
CLAIM_TARGET_REPO_DECLARED=0
CLAIM_ISSUE_BODY=""
POLLER_ID="${CODEX_POLL_ID:-${HOSTNAME:-poller}}"

log() {
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  printf '[%s] %s\n' "$ts" "$*" | tee -a "$LOG_FILE"
}

next_poll_generation() {
  local generation_file="$1"
  local last_generation=0
  local next_generation=1

  if [[ -f "$generation_file" ]]; then
    last_generation="$(tr -d '[:space:]' < "$generation_file" 2>/dev/null || true)"
    if [[ "$last_generation" =~ ^[0-9]+$ ]]; then
      next_generation=$((last_generation + 1))
    fi
  fi

  local generation_tmp
  if ! generation_tmp="$(mktemp "${generation_file}.XXXXXX")"; then
    log "failed to create temp file for poll_generation"
    return 1
  fi
  if ! printf '%s\n' "$next_generation" > "$generation_tmp"; then
    rm -f "$generation_tmp"
    return 1
  fi
  if ! mv "$generation_tmp" "$generation_file"; then
    rm -f "$generation_tmp"
    return 1
  fi

  printf '%s\n' "$next_generation"
}

emit_poll_heartbeat() {
  local state="$1"
  local last_claimed="${2:-}"
  local generation
  local payload
  local heartbeat_tmp

  if ! mkdir -p "$LIVENESS_STATE_DIR" 2>/dev/null; then
    log "warning: heartbeat state dir unavailable: ${LIVENESS_STATE_DIR}"
    return 0
  fi

  if ! generation="$(next_poll_generation "$LIVENESS_GENERATION_FILE")"; then
    log "warning: failed to advance poll_generation (non-fatal)"
    return 0
  fi

  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  if [[ -n "$last_claimed" ]]; then
    payload="$(jq -cn --arg agent_id "$POLLER_ID" --arg timestamp "$ts" --arg state "$state" --argjson poll_generation "$generation" --arg last_claimed "$last_claimed" '{agent_id:$agent_id, timestamp:$timestamp, poll_generation:$poll_generation, last_claimed:$last_claimed, state:$state}')"
  else
    payload="$(jq -cn --arg agent_id "$POLLER_ID" --arg timestamp "$ts" --arg state "$state" --argjson poll_generation "$generation" '{agent_id:$agent_id, timestamp:$timestamp, poll_generation:$poll_generation, last_claimed:null, state:$state}')"
  fi

  if [[ -z "$payload" ]]; then
    log "warning: failed to compose heartbeat payload"
    return 0
  fi

  heartbeat_tmp="$(mktemp "${LIVENESS_STATE_DIR}/.heartbeat.json.XXXXXX")" || {
    log "warning: failed to create heartbeat temp file in ${LIVENESS_STATE_DIR}"
    return 0
  }
  if ! printf '%s\n' "$payload" > "$heartbeat_tmp"; then
    rm -f "$heartbeat_tmp"
    log "warning: failed to write heartbeat temp file"
    return 0
  fi

  if ! mv "$heartbeat_tmp" "$LIVENESS_HEARTBEAT_FILE"; then
    rm -f "$heartbeat_tmp"
    log "warning: failed to write heartbeat atomically to ${LIVENESS_HEARTBEAT_FILE}"
    return 0
  fi
}

CODEX_CACHE_REPO="${CODEX_CACHE_REPO:-petersimmons1972/claude-codex}"

validate_cache_path() {
  local cache_dir="$1"

  if [[ -z "$cache_dir" ]]; then
    log "ERROR: CLAUDE_CODEX_CACHE resolved to an empty path"
    return 1
  fi

  if [[ "$cache_dir" != /* ]]; then
    log "ERROR: CLAUDE_CODEX_CACHE must be an absolute path"
    return 1
  fi

  if [[ "$cache_dir" != "${HOME}/.cache/"* ]]; then
    log "ERROR: CLAUDE_CODEX_CACHE must be under ${HOME}/.cache/"
    return 1
  fi

  if [[ -e "$cache_dir" ]]; then
    if [[ ! -d "$cache_dir" ]]; then
      log "ERROR: CLAUDE_CODEX_CACHE exists but is not a directory: $cache_dir"
      return 1
    fi

    local cache_owner
    local cache_mode
    local other_mode
    cache_owner="$(stat -c '%u' "$cache_dir")"
    cache_mode="$(stat -c '%a' "$cache_dir")"

    if [[ "$cache_owner" != "$(id -u)" ]]; then
      log "ERROR: CLAUDE_CODEX_CACHE must be owned by UID $(id -u)"
      return 1
    fi

    other_mode="${cache_mode: -1}"
    if (( (10#$other_mode & 2) != 0 )); then
      log "ERROR: CLAUDE_CODEX_CACHE has world-write permission enabled"
      return 1
    fi
  fi

  mkdir -p "$cache_dir"
  chmod 700 "$cache_dir"
}

load_expected_cache_sha() {
  CODEX_CACHE_REPO_SHA="${CODEX_CACHE_REPO_SHA:-$(tr -d '[:space:]' < "$CODEX_CACHE_SHA_FILE" 2>/dev/null || true)}"

  if [[ -z "$CODEX_CACHE_REPO_SHA" ]]; then
    log "ERROR: missing CODEX_CACHE_REPO_SHA and unable to read ${CODEX_CACHE_SHA_FILE}"
    return 1
  fi

  if [[ ! "$CODEX_CACHE_REPO_SHA" =~ ^[0-9a-f]{40}$ ]]; then
    log "ERROR: invalid CLAUDE_CODEX SHA pin: ${CODEX_CACHE_REPO_SHA}"
    return 1
  fi
}

refresh_target_repo_cache() {
  if ! load_expected_cache_sha; then
    return 1
  fi

  if [[ "$CODEX_CACHE_REPO" != petersimmons1972/* ]]; then
    log "ERROR: CODEX_CACHE_REPO '${CODEX_CACHE_REPO}' does not belong to the expected owner (petersimmons1972)"
    return 1
  fi

  if [[ ! -d "${CACHE_DIR}/.git" ]]; then
    log "cache miss: cloning ${CACHE_DIR} from ${CODEX_CACHE_REPO}"
    git clone --depth 1 \
      --config transfer.fsckObjects=true \
      "https://github.com/${CODEX_CACHE_REPO}" "$CACHE_DIR" >> "$LOG_FILE" 2>&1
  else
    log "refreshing target repo cache in ${CACHE_DIR}"
  fi

  if ! git -C "$CACHE_DIR" fetch --depth 1 "https://github.com/${CODEX_CACHE_REPO}" "${CODEX_CACHE_REPO_SHA}" >> "$LOG_FILE" 2>&1; then
    log "ERROR: failed to fetch pinned claude-codex revision ${CODEX_CACHE_REPO_SHA}"
    return 1
  fi

  if ! git -C "$CACHE_DIR" reset --hard "${CODEX_CACHE_REPO_SHA}" >> "$LOG_FILE" 2>&1; then
    log "ERROR: failed to verify/pin claude-codex cache to ${CODEX_CACHE_REPO_SHA}"
    return 1
  fi

  local cached_sha
  cached_sha="$(git -C "$CACHE_DIR" rev-parse --verify --short=40 HEAD)"
  if [[ "$cached_sha" != "$CODEX_CACHE_REPO_SHA" ]]; then
    log "ERROR: pinned claude-codex SHA mismatch (expected ${CODEX_CACHE_REPO_SHA}, got ${cached_sha})"
    return 1
  fi
}

load_target_repos() {
  if [[ ! -r "$TARGET_REPOS_FILE" ]]; then
    log "ERROR: target-repos cache file missing: $TARGET_REPOS_FILE"
    return 1
  fi

  mapfile -t TARGET_REPOS < <(
    sed -e 's/#.*$//' "$TARGET_REPOS_FILE" \
      | awk '{
          gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
          if ($0 != "") print $0
        }'
  )
}

repo_short_name() {
  local slug="$1"
  echo "${slug##*/}"
}

issue_repo_path() {
  local slug="$1"
  printf '%s/%s\n' "$PROJECTS_ROOT" "$(repo_short_name "$slug")"
}

target_repo_path() {
  local slug="$1"
  issue_repo_path "$slug"
}

extract_target_repo_from_body() {
  python3 - "$1" <<'PY'
import re
import sys

body = sys.argv[1]
m = re.search(r'(?mi)^Target-Repo:\s*([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)\s*$', body)
if m:
    print(m.group(1))
PY
}

find_external_file_refs_without_target_repo() {
  local queue_repo="$1" body="$2"
  python3 - "$queue_repo" "$body" <<'PY'
import re
import sys

queue_repo = sys.argv[1]
body = sys.argv[2]
queue_short = queue_repo.rsplit("/", 1)[-1]
matches = []
in_files = False
for line in body.splitlines():
    if line.startswith("## "):
        in_files = (line == "## Files")
        continue
    if not in_files:
        continue
    for pattern in (r'~/projects/([^/\s]+)/', r'\$\{PROJECTS_ROOT\}/([^/\s]+)/'):
        for repo in re.findall(pattern, line):
            if repo != queue_short and repo not in matches:
                matches.append(repo)
if matches:
    print(",".join(matches))
PY
}

warn_queue_issue() {
  local queue_repo="$1" issue="$2" message="$3"
  log "warning: ${message}"
  gh issue comment "$issue" --repo "$queue_repo" --body "$message" >>"$LOG_FILE" 2>&1 || true
}

extract_report_repo_from_log() {
  python3 - "$1" <<'PY' 2>/dev/null || true
import re
import sys

try:
    txt = open(sys.argv[1], encoding="utf-8", errors="replace").read()
except Exception:
    sys.exit(0)

blocks = re.findall(r"=== CODEX REPORT ===(.*?)\n=+\n", txt, re.S)
if not blocks:
    sys.exit(0)

m = re.search(r"(?mi)^\s*repo\s*:\s*(.*)$", blocks[-1])
if m:
    print(m.group(1).strip())
PY
}

log_skipped_issue() {
  log "skip: $1#$2 (${3:-reason unknown})"
}

poll_queued_candidates() {
  local tmp="$1"
  : > "$tmp"

  local repo rows
  for repo in "${TARGET_REPOS[@]}"; do
    if ! rows="$(gh issue list \
      --repo "$repo" \
      --label "$QUEUE_LABEL" \
      --state open \
      --json number,title,labels,createdAt \
      2>/dev/null || echo "[]")"
    then
      rows="[]"
    fi

    if [[ "$rows" == "[]" ]]; then
      continue
    fi

    while IFS= read -r row; do
      printf '%s\n' "$row" | jq --arg repo "$repo" -c '. + {repository:{nameWithOwner:$repo}}' >> "$tmp"
    done < <(printf '%s\n' "$rows" | jq -c '.[]')
  done
}

sort_candidates() {
  local tmp="$1"

  python3 - "$tmp" <<'PY'
import json
import sys

path = sys.argv[1]
items = []
with open(path, "r", encoding="utf-8") as fh:
    for raw in fh:
        raw = raw.strip()
        if not raw:
            continue
        payload = json.loads(raw)
        names = [label.get("name", "") for label in payload.get("labels", [])]
        if "agent/codex/queued" not in names:
            continue
        if "decision/needs-founder" in names:
            continue
        if "priority/p0" in names:
            priority = 0
        elif "priority/p1" in names:
            priority = 1
        elif "priority/p2" in names:
            priority = 2
        elif "priority/p3" in names:
            priority = 3
        else:
            priority = 9

        payload["priority"] = priority
        payload["label_names"] = names
        items.append(payload)

items.sort(key=lambda item: (item["priority"], item.get("createdAt", "")))
for item in items:
    print(json.dumps(item))
PY
}

build_queue_brief() {
  # Build a QUEUE_BRIEF block summarising the current queue state.
  # Arguments:
  #   $1 sorted_file  -- JSONL file of all eligible queued issues (from sort_candidates)
  #   $2 current_repo -- owner/repo of the issue being claimed
  #   $3 current_num  -- number of the issue being claimed
  #
  # Outputs the brief block to stdout; never exits non-zero (failure → empty brief).
  local sorted_file="$1"
  local current_repo="$2"
  local current_num="$3"

  [[ -s "$sorted_file" ]] || return 0

  python3 - "$sorted_file" "$current_repo" "$current_num" <<'PY' || return 0
import json
import sys
import re

sorted_path, current_repo, current_num_str = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    current_num = int(current_num_str)
except ValueError:
    sys.exit(0)

items = []
with open(sorted_path, "r", encoding="utf-8") as fh:
    for raw in fh:
        raw = raw.strip()
        if not raw:
            continue
        try:
            items.append(json.loads(raw))
        except json.JSONDecodeError:
            pass

# Count by priority across all repos
counts = {0: 0, 1: 0, 2: 0, 3: 0, 9: 0}
for item in items:
    counts[item.get("priority", 9)] += 1

total = len(items)
p_str = f"p0={counts[0]}, p1={counts[1]}, p2={counts[2]}, p3={counts[3]}"

# Find same-repo queued siblings (exclude the issue being claimed)
siblings = [
    item for item in items
    if item.get("repository", {}).get("nameWithOwner", "") == current_repo
    and item.get("number") != current_num
]

# Build output — cap at 20 lines total
lines = [
    "=== QUEUE_BRIEF ===",
    f"total_queued: {total} ({p_str})",
    f"this_issue: #{current_num} (repo={current_repo})",
    "same_repo_queued:",
]

if siblings:
    for sib in siblings[:10]:
        pnum = sib.get("priority", 9)
        plabel = f"p{pnum}" if pnum != 9 else "p?"
        title = sib.get("title", "")[:60]
        lines.append(f"  - #{sib['number']} {plabel} — {title}")
else:
    lines.append("  (none)")

# Conflict surfaces: extract file-like tokens from current issue title as proxy
# (bodies are not available in the sorted file — we avoid an extra API call)
lines.append("conflict_surfaces: -")
lines.append("=== END QUEUE_BRIEF ===")

# Hard cap at 20 lines
output = "\n".join(lines[:20])
print(output)
PY
}

consume_webhook_event_file() {
  local events_dir="$1"
  local state_dir="$2"

  local event_file
  event_file="$(find "$events_dir" -maxdepth 1 -type f -name '*.json' -print 2>/dev/null | sort | head -n 1 || true)"
  if [[ -z "$event_file" ]]; then
    return 1
  fi

  local staged_file
  staged_file="$(mktemp "${state_dir}/webhook-event.XXXXXX.json")"
  if ! mv "$event_file" "$staged_file"; then
    rm -f "$staged_file"
    return 1
  fi

  printf '%s\n' "$staged_file"
}

release_claimed_issue() {
  local repo="$1"
  local issue_number="$2"

  gh issue edit "$issue_number" \
    --repo "$repo" \
    --add-label "$QUEUE_LABEL" \
    --remove-label "$WORKING_LABEL" >>"$LOG_FILE" 2>&1 || \
    log "WARNING: failed to revert label state for ${repo}#${issue_number}"
}

claim_issue() {
  local repo="$1"
  local issue_number="$2"
  CLAIM_SKIP_REASON=""
  CLAIM_TARGET_REPO=""
  CLAIM_TARGET_REPO_PATH=""
  CLAIM_TARGET_REPO_DECLARED=0
  CLAIM_ISSUE_BODY=""
  local owner
  local project
  local issue_response
  local issue_etag
  local issue_json
  local issue_labels
  local issue_body
  local issue_state
  local brief_id
  local issue_resource
  local patch_body
  local updated_labels
  owner="${repo%%/*}"
  project="${repo#*/}"
  issue_resource="repos/${owner}/${project}/issues/${issue_number}"

  issue_response="$(gh api --include --method GET "$issue_resource")"
  # Match the ETag header case-insensitively WITHOUT gawk's IGNORECASE (mawk,
  # the Debian/Ubuntu default awk, ignores it). GitHub returns "Etag:".
  issue_etag="$(printf '%s\n' "$issue_response" | awk 'tolower($1) == "etag:" { sub("\\r", "", $2); print $2; exit }')"
  issue_json="$(printf '%s\n' "$issue_response" | sed -n '/^{/,$p')"

  if [[ -z "$issue_etag" || -z "$issue_json" ]]; then
    log "ERROR: failed to read issue state for ${repo}#${issue_number}"
    return 1
  fi

  issue_labels="$(printf '%s\n' "$issue_json" | jq -r '.labels[].name')"
  issue_body="$(printf '%s\n' "$issue_json" | jq -r '.body // empty')"
  CLAIM_ISSUE_BODY="$issue_body"

  if printf '%s\n' "$issue_labels" | grep -Fxq "$WORKING_LABEL"; then
    CLAIM_SKIP_REASON="already-in-progress"
    log_skipped_issue "$repo" "$issue_number" "already in progress"
    return 1
  fi

  if printf '%s\n' "$issue_labels" | grep -Fxq "$NEEDS_CLAUDE_LABEL"; then
    log_skipped_issue "$repo" "$issue_number" "needs-claude escalation"
    log "skip: ${repo}#${issue_number} action=skipped-needs-claude"
    return 1
  fi

  # If issue is no longer blocked with needs-claude, clear stale 3+ strike entries.
  if [[ -n "${STRIKE_TOOL:-}" ]]; then
    reset_3plus_issue_strikes "$repo" "$issue_number" >>"$LOG_FILE" 2>&1 || true
  fi

  if ! printf '%s\n' "$issue_labels" | grep -Fxq "$QUEUE_LABEL"; then
    CLAIM_SKIP_REASON="no-longer-queued"
    log_skipped_issue "$repo" "$issue_number" "no longer queued"
    return 1
  fi

  issue_state="$(issue_state_from_labels "$issue_labels")"
  if ! is_valid_transition "${issue_state}" "processing"; then
    CLAIM_SKIP_REASON="invalid-state-transition"
    log_skipped_issue "$repo" "$issue_number" "invalid state transition (${issue_state} -> processing)"
    return 1
  fi

  brief_id="$(derive_brief_id "$repo" "$issue_number" "$issue_body")"
  terminal_db_ensure
  if terminal_state_is_processed "$brief_id"; then
    # F2 (#60): label-wins re-queue rule — if the issue carries `queued` label and
    # NO terminal label in GitHub, AND the stored issue_ref matches this issue,
    # the operator intentionally re-opened it.  Clear the ledger entry and allow
    # re-execution.  If issue_ref does NOT match (dedupe scenario: different issue
    # with same brief_id), ledger-wins: skip the second issue to avoid redundant runs.
    local stored_issue_ref
    stored_issue_ref="$(jq -r --arg id "$brief_id" '.[$id].issue_ref // empty' "$TERMINAL_STATE_FILE" 2>/dev/null || true)"
    local same_issue=0
    if [[ -z "$stored_issue_ref" || "$stored_issue_ref" == "${repo}#${issue_number}" ]]; then
      same_issue=1
    fi
    local has_terminal_label=0
    for _tl in "$DONE_LABEL" "$STALLED_LABEL" "$BLOCKED_LABEL" "$NEEDS_INPUT_LABEL"; do
      if printf '%s\n' "$issue_labels" | grep -Fxq "$_tl"; then
        has_terminal_label=1
        break
      fi
    done
    if [[ "$same_issue" -eq 1 && "$has_terminal_label" -eq 0 ]]; then
      log "re-queue detected for ${repo}#${issue_number}: ledger entry for brief ${brief_id} cleared (queued label present, no terminal label)"
      terminal_state_clear "$brief_id"
      gh issue comment "$issue_number" --repo "$repo"         --body "codex-poll: re-queue detected — ledger entry cleared, issue will be re-executed."         >>"$LOG_FILE" 2>&1 || true
    else
      CLAIM_SKIP_REASON="already-processed"
      log_skipped_issue "$repo" "$issue_number" "brief ${brief_id} already processed"
      return 1
    fi
  fi

  if printf '%s\n' "$issue_labels" | grep -Fxq "$HOLD_LABEL"; then
    CLAIM_SKIP_REASON="founder-decision-hold"
    log_skipped_issue "$repo" "$issue_number" "founder decision hold"
    return 1
  fi

  CLAIM_TARGET_REPO="$(extract_target_repo_from_body "$issue_body")"
  if [[ -n "${CLAIM_TARGET_REPO:-}" ]]; then
    CLAIM_TARGET_REPO_DECLARED=1
    CLAIM_TARGET_REPO_PATH="$(target_repo_path "$CLAIM_TARGET_REPO")"
  else
    CLAIM_TARGET_REPO="$repo"
    CLAIM_TARGET_REPO_PATH="$(issue_repo_path "$repo")"
    local external_refs
    external_refs="$(find_external_file_refs_without_target_repo "$repo" "$issue_body")"
    if [[ -n "${external_refs:-}" ]]; then
      warn_queue_issue "$repo" "$issue_number" \
        "queue issue ${repo}#${issue_number} references external repo path(s) ${external_refs} without Target-Repo metadata"
    fi
  fi

  updated_labels="$(printf '%s\n' "$issue_json" | jq -c --arg queue "$QUEUE_LABEL" --arg working "$WORKING_LABEL" '(.labels | map(.name) | map(select(. != $queue and . != $working)) + [$working] | unique)')"
  if [[ -z "$updated_labels" ]]; then
    log "claim aborted for ${repo}#${issue_number}: failed to compute updated labels"
    return 1
  fi
  patch_body="$(jq -cn --argjson labels "$updated_labels" '{labels: $labels}')"

  # NOTE: GitHub's Issues API rejects conditional headers on PATCH (400
  # "Conditional request headers are not allowed in unsafe requests"), so the
  # old If-Match compare-and-swap never worked against real GitHub. A single
  # pidfile-serialized poller cannot race itself, and we re-checked the queued
  # label above, so a plain label PATCH is the correct claim here.
  if ! printf '%s\n' "$patch_body" | gh api --method PATCH \
    "$issue_resource" \
    --input - \
    >>"$LOG_FILE" 2>&1; then
    log "claim label update failed for ${repo}#${issue_number}"
    return 1
  fi

  CLAIM_BRIEF_ID="$brief_id"

  return 0
}

default_branch() {
  local repo_path="$1"
  git -C "$repo_path" symbolic-ref --short "refs/remotes/${REMOTE_NAME}/HEAD" 2>/dev/null \
    | sed "s#^${REMOTE_NAME}/##" || echo "main"
}

launch_coded_issue() {
  local queue_repo="$1"
  local issue_number="$2"
  local worktree="$3"
  local branch="$4"
  local queue_brief="${5:-}"
  local target_repo="${6:-$queue_repo}"
  LAST_RUN_EXIT=0

  local handoff=""
  if [[ -x "$HANDOFF_BIN" ]]; then
    handoff="$("$HANDOFF_BIN" --repo "$worktree" --root "$PROJECTS_ROOT" --json 2>/dev/null || true)"
  fi

  local issue_body
  issue_body="$(gh issue view "$issue_number" --repo "$queue_repo" --json body --jq '.body' 2>/dev/null || echo "")"

  local prompt_file
  prompt_file="$(mktemp)"
  {
    if [[ -n "${queue_brief:-}" ]]; then
      printf '%s\n\n' "$queue_brief"
    fi
    cat <<EOF
You are Codex. Pick up this GitHub issue and execute it end-to-end.

Issue: ${queue_repo}#${issue_number}
Working directory: ${worktree}
Branch: ${branch}
Target repo: ${target_repo}

Issue body:
${issue_body}

Codex handoff context:
${handoff}

When reporting progress back to Claude, always include this status contract block:
=== CODEX REPORT ===
issue: #${issue_number}
repo: ${target_repo}
status: in-progress | done | blocked | needs-input
pr: <url | ->
commits: <hash[,hash] | ->
tests: <test-file::name(s) + suite result>
tdd: <failing-test-first ✓ | coverage-retained ✓ | n/a (no code change)>
needs: <blocker/decision if any | ->
qa_round1: blockers=0, critical=0, serious=0, friction=0, nitpick=0
qa_round2: blockers=0, critical=0, serious=0, friction=0, nitpick=0
qa_issues: -
qa_mode: full
notes: <short summary>
==================
Follow protocol/message-contract.md and protocol/label-state-machine.md in petersimmons1972/claude-codex.
Do not touch the shared checkout for ${target_repo} outside the provided worktree.
EOF
  } > "$prompt_file"

  local run_log
  run_log="${STATE_DIR}/run-${issue_number}-$(date -u +%Y%m%dT%H%M%S).log"
  LAST_RUN_LOG="$run_log"
  if ! "$CODEX_BIN" exec --ephemeral --cd "$worktree" < "$prompt_file" > "$run_log" 2>&1; then
    rm -f "$prompt_file"
    LAST_RUN_EXIT=1
    log "ERROR: codex invocation failed for ${queue_repo}#${issue_number}"
    return 1
  fi
  LAST_RUN_EXIT=0
  rm -f "$prompt_file"
}

remove_worktree() {
  local repo_path="$1"
  local worktree="$2"
  local issue="$3"
  local expected_prefix="${WORKTREES_ROOT%/}/"

  if [[ "$worktree" != "${expected_prefix}"* ]]; then
    log "unsafe worktree path blocked: ${worktree}"
    return 1
  fi

  if [[ -d "$worktree" ]]; then
    # F1 (#60): one-shot guard — if a prior call (e.g. recover_unpublished on push
    # failure) already preserved this worktree, the RETURN trap's second call must be
    # a no-op. Without this guard the worktree is preserved + logged twice.
    if [[ -f "${worktree}/.preserved" ]]; then
      return 0
    fi
    # F1 (#60): if the worktree still has uncommitted or unpushed work, preserve it
    # instead of force-removing. Safety lives here — callers cannot bypass this.
    if worktree_has_work "$repo_path" "$worktree" 2>/dev/null; then
      local head_sha
      head_sha="$(git -C "$worktree" rev-parse --short HEAD 2>/dev/null || echo unknown)"
      local branch_name
      branch_name="$(git -C "$worktree" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
      touch "${worktree}/.preserved" 2>/dev/null || true
      log "preserved worktree ${worktree} for issue ${issue} (branch=${branch_name} sha=${head_sha}) — work present, not removed"
      return 0
    fi
    log "removing worktree ${worktree}"
    git -C "$repo_path" worktree remove --force "$worktree" >>"$LOG_FILE" 2>&1 || \
      log "WARNING: failed to remove worktree ${worktree} for issue ${issue}"
  fi
}

# list_preserved_worktrees — print the path of every preserved worktree (one per line).
# A preserved worktree is any immediate child of WORKTREES_ROOT containing a .preserved marker.
list_preserved_worktrees() {
  [[ -d "$WORKTREES_ROOT" ]] || return 0
  find "$WORKTREES_ROOT" -mindepth 1 -maxdepth 2 -name '.preserved' -printf '%h\n' 2>/dev/null | sort -u
}

# count_and_warn_preserved_worktrees — per-cycle observability for the F1 leak.
# Logs a COUNT + warning of accumulated .preserved worktrees. NEVER deletes anything;
# deletion is reserved for the explicit `prune-preserved` subcommand (advisory: count/warn
# per cycle, never auto-delete — re-deleting unrecovered work is the higher-cost failure).
count_and_warn_preserved_worktrees() {
  local count
  count="$(list_preserved_worktrees | grep -c . || true)"
  count="${count:-0}"
  if [[ "$count" -gt 0 ]]; then
    log "WARNING: preserved-worktree leak observable: count=${count} under ${WORKTREES_ROOT} — run 'codex-poll prune-preserved' to reclaim safe ones"
  fi
}

# head_contained_in_origin WORKTREE BRANCH — succeed ONLY IF the worktree's local HEAD
# is fully reachable from the origin branch tip (no unpushed local commits). A name-only
# existence check is insufficient: a branch can be on origin at sha X while the worktree
# accrued local commits to sha Y>X — pruning then loses commits X+1..Y. We fetch the
# branch to refresh the remote-tracking ref, then require rev-list origin/<branch>..HEAD == 0.
head_contained_in_origin() {
  local worktree="$1" branch="$2"
  [[ -n "$branch" ]] || return 1
  # The branch must exist on origin at all (else there is nothing to be contained in).
  local lsr
  lsr="$(git -C "$worktree" ls-remote --heads "$REMOTE_NAME" "$branch" 2>/dev/null || true)"
  [[ -n "$lsr" ]] || return 1
  # Refresh the remote-tracking ref so the containment comparison uses the real origin tip.
  git -C "$worktree" fetch "$REMOTE_NAME" "$branch" >/dev/null 2>&1 || true
  # Count commits in HEAD that are NOT reachable from the origin branch tip.
  local ahead
  ahead="$(git -C "$worktree" rev-list --count "${REMOTE_NAME}/${branch}..HEAD" 2>/dev/null || echo 1)"
  [[ "${ahead:-1}" -eq 0 ]]
}

# prune_preserved [--older-than-days N] — remove preserved worktrees that are CONFIRMED
# safe (branch pushed to origin) AND older than N days (default 7). Worktrees whose branch
# is not on origin (unpushed commits) are ALWAYS skipped — never auto-delete unrecovered
# work. Reports each removal and each skip with its reason.
prune_preserved() {
  local older_than_days=7
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --older-than-days)
        older_than_days="${2:-7}"; shift 2 ;;
      *)
        shift ;;
    esac
  done

  if [[ ! -d "$WORKTREES_ROOT" ]]; then
    log "prune-preserved: WORKTREES_ROOT ${WORKTREES_ROOT} absent — nothing to do"
    return 0
  fi

  local now cutoff removed=0 skipped=0
  now="$(date +%s)"
  cutoff="$(( older_than_days * 86400 ))"

  local wt
  while IFS= read -r wt; do
    [[ -n "$wt" ]] || continue
    local marker="${wt}/.preserved"
    [[ -f "$marker" ]] || continue

    # Age check (mtime of the marker).
    local mtime age
    mtime="$(stat -c %Y "$marker" 2>/dev/null || echo "$now")"
    age="$(( now - mtime ))"
    if [[ "$age" -lt "$cutoff" ]]; then
      log "prune-preserved: skipped ${wt} — younger than ${older_than_days}d (age=$(( age / 86400 ))d)"
      skipped=$(( skipped + 1 ))
      continue
    fi

    # Safety check: the worktree's local HEAD must be fully CONTAINED in the origin
    # branch tip (no unpushed local commits). Branch-name existence alone is unsafe —
    # see head_contained_in_origin. Any HEAD ahead of origin is unrecovered work → SKIP.
    local branch repo_path
    branch="$(git -C "$wt" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
    repo_path="$(git -C "$wt" rev-parse --show-toplevel 2>/dev/null || echo "$wt")"
    if [[ -z "$branch" ]] || ! head_contained_in_origin "$wt" "$branch"; then
      log "prune-preserved: skipped ${wt} — branch '${branch:-unknown}' HEAD not contained in origin tip (unpushed work; never auto-deleted)"
      skipped=$(( skipped + 1 ))
      continue
    fi

    # Confirmed safe (HEAD on origin) + old → remove, then prune stale registration.
    git -C "$repo_path" worktree remove --force "$wt" >>"$LOG_FILE" 2>&1 || rm -rf "$wt"
    rm -rf "$wt" 2>/dev/null || true
    git -C "$repo_path" worktree prune >>"$LOG_FILE" 2>&1 || true
    log "prune-preserved: removed ${wt} — branch '${branch}' HEAD contained in origin, age=$(( age / 86400 ))d"
    removed=$(( removed + 1 ))
  done < <(list_preserved_worktrees)

  log "prune-preserved: done — removed=${removed} skipped=${skipped} threshold=${older_than_days}d"
  return 0
}

LAST_RUN_LOG=""
LAST_RUN_EXIT=0

# reset_3plus_issue_strikes REPO ISSUE — if issue does not carry needs-claude, clear any
# issue-level strike buckets at or above the 3-strike threshold. This is the
# "human reset" path after a manual unblock.
reset_3plus_issue_strikes() {
  local repo="$1"
  local issue="$2"
  if [[ -z "${STRIKE_TOOL:-}" ]]; then
    return 0
  fi
  python3 "$STRIKE_TOOL" \
    --state-dir "$STRIKE_STATE_DIR" \
    --window-seconds "$STRIKE_WINDOW_SECONDS" \
    clear-issue --issue "${repo}#${issue}" --threshold 3 >/dev/null 2>&1 || true
}

# extract_strike_from_log RUN_LOG — print JSON payload with `fingerprint` and `error`.
extract_strike_from_log() {
  local log_file="$1"
  python3 - "$log_file" <<'PY'
import re
import sys
import json

path = sys.argv[1]
try:
    txt = open(path, "r", encoding="utf-8", errors="replace").read().splitlines()
except OSError:
    print(json.dumps({}))
    raise SystemExit(0)

for line in txt:
    m = re.search(r"^STRIKE:\s*fingerprint=([^\s]+)\s+error=(.*)$", line)
    if m:
        payload = {"fingerprint": m.group(1), "error": m.group(2).rstrip()}
        print(json.dumps(payload))
        raise SystemExit(0)

print(json.dumps({}))
PY
}

# process_failure_strike REPO ISSUE RUN_LOG STATUS — record a strike and escalate on 3.
process_failure_strike() {
  local repo="$1"
  local issue="$2"
  local run_log="$3"
  local status="$4"

  [[ -f "$run_log" ]] || return 0
  if [[ -z "$STRIKE_TOOL" ]]; then
    return 0
  fi

  local strike_json fingerprint error payload count ts escalation_body
  strike_json="$(extract_strike_from_log "$run_log")"
  fingerprint="$(python3 -c 'import json,sys;print(json.loads(sys.stdin.read() or "{}").get("fingerprint",""))' <<< "$strike_json")"
  if [[ -z "$fingerprint" ]]; then
    return 0
  fi

  error="$(python3 -c 'import json,sys;print(json.loads(sys.stdin.read() or "{}").get("error",""))' <<< "$strike_json")"

  payload="$(python3 "$STRIKE_TOOL" \
      --state-dir "$STRIKE_STATE_DIR" \
      --window-seconds "$STRIKE_WINDOW_SECONDS" \
      record \
      --key "${repo}#${issue}:${fingerprint}" \
      --error "$error" \
    2>/dev/null || true)"
  # Bail before commenting if the strike tool errored or returned no usable count
  # (otherwise a tool failure would post a misleading "Strike 0/3" comment).
  if ! python3 -c 'import json,sys
try:
    p = json.loads(sys.stdin.read() or "{}")
except Exception:
    sys.exit(1)
sys.exit(0 if (isinstance(p.get("count"), int) and "error" not in p) else 1)' <<< "$payload"; then
    log "strike: skipping comment for ${repo}#${issue} — strike tool returned no count (payload: ${payload:-<empty>})"
    return 0
  fi

  count="$(python3 -c 'import json,sys; 
p = json.loads(sys.stdin.read() or "{}"); 
print(p.get("count", 0))' <<< "$payload")"
  ts="$(python3 -c 'import json,sys;
p = json.loads(sys.stdin.read() or "{}"); 
entries = p.get("entries", [])
print(entries[-1].get("ts", "") if entries else "")' <<< "$payload")"

  gh issue comment "$issue" --repo "$repo" \
    --body "Strike ${count}/3 | fingerprint: ${fingerprint} | error: ${error} | ts: ${ts}" \
    >>"$LOG_FILE" 2>&1 || true

  if (( count >= 3 )); then
    local strike_entries
    strike_entries="$(python3 -c 'import json,sys
p = json.loads(sys.stdin.read() or "{}")
entries = p.get("entries", [])[-3:]
print("\\n".join([f"{i}. {entry.get(\"ts\", \"\")} | {entry.get(\"error\", \"\")}" for i, entry in enumerate(entries, 1)]))' <<< "$payload")"
    escalation_body="$(cat <<EOF
Protocol 14 3-strike escalation for ${repo}#${issue}

Fingerprint: ${fingerprint}
Recent strikes:
${strike_entries}

This issue reached 3 strikes in the configured 72-hour window. Added:
- ${NEEDS_CLAUDE_LABEL}
- ${BLOCKED_LABEL}

Recommended next action: triage the root cause, then remove ${NEEDS_CLAUDE_LABEL}
to re-enable dispatch. This resets this strike counter.
EOF
)"
    gh issue edit "$issue" --repo "$repo" \
      --add-label "$NEEDS_CLAUDE_LABEL" \
      --add-label "$BLOCKED_LABEL" \
      --remove-label "$QUEUE_LABEL" \
      --remove-label "$WORKING_LABEL" >>"$LOG_FILE" 2>&1 || true
    gh issue comment "$issue" --repo "$repo" --body "$escalation_body" >>"$LOG_FILE" 2>&1 || true
    log "fast: 3-strike escalation for ${repo}#${issue} fingerprint=${fingerprint}"
    return 0
  fi

  return 0
}

# set_issue_state REPO ISSUE ADD_LABEL — add a terminal label and clear WORKING_LABEL.
set_issue_state() {
  local repo="$1" issue="$2" add="$3"
  gh issue edit "$issue" --repo "$repo" --add-label "$add" --remove-label "$WORKING_LABEL" >>"$LOG_FILE" 2>&1 \
    || log "WARNING: failed to set ${add} on ${repo}#${issue}"
}

# parse_codex_report RUN_LOG — print "status<TAB>result_ref<TAB>qa_present(0|1)<TAB>failure_reason<TAB>result_kind<TAB>actor<TAB>timestamp".
# Supports:
#  - JSON TerminalResult log lines (preferred contract output).
#  - Legacy === CODEX REPORT === blocks.
parse_codex_report() {
  python3 - "$1" <<'PY' 2>/dev/null || printf 'failed\t-\t0\t\tnone\tcodex\t-\n'
import json
import re
import sys

path = sys.argv[1]

try:
    txt = open(path, encoding="utf-8", errors="replace").read()
except Exception:
    print("failed\t-\t0\t\tnone\tcodex\t-")
    sys.exit(0)

def _json_status(value):
    # F3/F4 (#60): JSON-path status hardening.
    #   - empty/absent           -> "failed" (conservative; never silently "done")
    #   - template ('|','<','>') -> "failed" (a placeholder is never a real outcome)
    #   - processing/in-progress/queued/unknown -> passthrough: these are the
    #     legitimate "defer to PR-state verification" signal; map_terminal_outcome_to_state
    #     routes them to "processing" so post_run_verify decides from the published artifact.
    #   - anything else          -> passthrough (terminal statuses + reasons handled downstream)
    v = (value or "").strip().lower()
    if not v:
        return "failed"
    if "|" in v or "<" in v or ">" in v:
        return "failed"
    return v

def terminal_to_tab(payload):
    # F3/F4 (#60): default to "failed" not "done"; reject template statuses; preserve defer.
    status = _json_status(str(payload.get("status", "")))
    result_kind = str(payload.get("result_kind", "")).strip().lower() or "none"
    result_ref = str(payload.get("result_ref", "")).strip() or "-"
    actor = str(payload.get("actor", "")).strip() or "codex"
    timestamp = str(payload.get("timestamp", "")).strip() or "-"
    failure_reason = payload.get("failure_reason")
    if failure_reason is None:
        failure_reason = ""
    else:
        failure_reason = str(failure_reason).strip()
    return "\t".join([status, result_ref, "0", failure_reason, result_kind, actor, timestamp])

for raw in reversed(txt.splitlines()):
    line = raw.strip()
    if not line.startswith("{") or not line.endswith("}"):
        continue
    try:
        payload = json.loads(line)
    except Exception:
        continue
    required_keys = {"status", "result_kind", "result_ref", "actor", "timestamp"}
    if not required_keys.issubset(set(payload.keys())):
        continue
    print(terminal_to_tab(payload))
    sys.exit(0)

blocks = re.findall(r"=== CODEX REPORT ===(.*?)(?:\n=+\n|\Z)", txt, re.S)
if not blocks:
    print("failed\t-\t0\t\tnone\tcodex\t-")
    sys.exit(0)

def field(name, block):
    m = re.search(r"(?mi)^\s*%s\s*:\s*(.*)$" % re.escape(name), block)
    return m.group(1).strip() if m else ""

def is_concrete_status(value):
    # F4 (#60): whitelist exactly the five terminal values; reject processing/in-progress/
    # queued/unknown/template values.
    CONCRETE = {"done", "blocked", "stalled", "failed", "needs-input"}
    value = (value or "").strip().lower()
    if not value:
        return False
    if "|" in value or "<" in value or ">" in value:
        return False
    return value in CONCRETE

selected = None
for b in reversed(blocks):
    if is_concrete_status(field("status", b)):
        selected = b
        break

if selected is None:
    selected = blocks[-1]

b_status = field("status", selected).strip().lower()
# F3+F4 (#60): empty/absent/non-terminal status maps to "failed" conservatively.
# A non-concrete status (processing, in-progress, queued, unknown, template) is
# not a terminal outcome — treat it as failed so it never silently becomes done.
CONCRETE_STATUSES = {"done", "blocked", "stalled", "failed", "needs-input"}
status = b_status if b_status in CONCRETE_STATUSES else "failed"
pr = field("pr", selected)
pr = pr if pr else "-"
qa = "1" if re.search(r"(?mi)^\s*qa_round", selected) else "0"
failure_reason = field("failure_reason", selected)
result_kind = field("result_kind", selected).strip().lower() or "none"
actor = field("actor", selected) or "codex"
timestamp = field("timestamp", selected) or "-"
failure_reason = failure_reason if failure_reason else "-"
print("%s\t%s\t%s\t%s\t%s\t%s\t%s" % (status, pr, qa, failure_reason, result_kind, actor, timestamp))
PY
}

# worktree_has_work REPO_PATH WORKTREE — succeed if uncommitted or unpushed commits exist.
worktree_has_work() {
  local repo_path="$1" worktree="$2"
  [[ -d "$worktree" ]] || return 1
  [[ -n "$(git -C "$worktree" status --porcelain 2>/dev/null)" ]] && return 0
  local base n
  base="$(default_branch "$repo_path")"
  n="$(git -C "$worktree" rev-list --count "${REMOTE_NAME}/${base}..HEAD" 2>/dev/null || echo 0)"
  [[ "${n:-0}" -gt 0 ]]
}

# recover_unpublished REPO ISSUE BRANCH WORKTREE REPO_PATH — #22: commit+push+draft PR so finished
# work is not lost when the worktree is removed. Recovery now publishes as done because the
# artifact contract is satisfied (branch+open draft PR).
recover_unpublished() {
  local queue_repo="$1" target_repo="$2" issue="$3" branch="$4" worktree="$5" repo_path="$6"
  log "post-verify: recovering unpublished work for ${queue_repo}#${issue} in ${target_repo} on ${branch}"
  if [[ -n "$(git -C "$worktree" status --porcelain 2>/dev/null)" ]]; then
    git -C "$worktree" add -A >>"$LOG_FILE" 2>&1 || true
    git -C "$worktree" -c user.email=codex-poll@local -c user.name=codex-poll \
      commit -q -m "chore(#${issue}): recover codex work (auto-committed by codex-poll, claude-codex#22)" >>"$LOG_FILE" 2>&1 || true
  fi
  if ! git -C "$worktree" push -u "$REMOTE_NAME" "HEAD:${branch}" >>"$LOG_FILE" 2>&1; then
    local push_sha push_branch
    push_sha="$(git -C "$worktree" rev-parse --short HEAD 2>/dev/null || echo unknown)"
    push_branch="$(git -C "$worktree" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
    # F1 (#60): on push failure, preserve the worktree instead of returning 0 and
    # letting the trap force-remove committed-but-unpushed work.
    touch "${worktree}/.preserved" 2>/dev/null || true
    log "preserved worktree ${worktree} for ${queue_repo}#${issue} (branch=${push_branch} sha=${push_sha}) — push failed, work preserved"
    log "post-verify: recovery push failed for ${queue_repo}#${issue}"
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"; return 0
  fi
  local base url
  base="$(default_branch "$repo_path")"
  if url="$(gh pr create --repo "$target_repo" --head "$branch" --base "$base" --draft \
        --title "[codex-poll recovered] ${queue_repo}#${issue}" \
        --body "Auto-recovered unpublished Codex work for #${issue} (claude-codex#22). Draft — needs review/CI. Closes #${issue}" 2>>"$LOG_FILE")"; then
    log "post-verify: recovered ${queue_repo}#${issue} -> draft PR ${url} in ${target_repo} (published artifact present)"
    set_issue_state "$queue_repo" "$issue" "$DONE_LABEL"
  else
    log "post-verify: recovery PR create failed for ${queue_repo}#${issue}"
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"; return 0
  fi
  return 0
}

# post_run_verify REPO ISSUE BRANCH WORKTREE REPO_PATH RUN_LOG — label the issue after a run.
# Ported from the interim poller, hardened for the canonical (synchronous; worktree still present).
# Handles: explicit blocked/needs-input (report) · read-only review w/ no PR (#21) ·
# publish-only completion for PRs (#20) · unpublished work recovery (#22).
post_run_verify() {
  local queue_repo="$1" target_repo="$2" issue="$3" branch="$4" worktree="$5" repo_path="$6" run_log="$7" brief_id="$8" target_declared="${9:-0}"
  local rep status pr qa mapped_status failure_reason result_kind actor timestamp mapped_failure_reason
  rep="$(parse_codex_report "$run_log")"
  status="$(cut -f1 <<<"$rep")"
  pr="$(cut -f2 <<<"$rep")"
  qa="$(cut -f3 <<<"$rep")"
  failure_reason="$(cut -f4 <<<"$rep")"
  result_kind="$(cut -f5 <<<"$rep")"
  actor="$(cut -f6 <<<"$rep")"
  timestamp="$(cut -f7 <<<"$rep")"
  mapped_status="$(map_terminal_outcome_to_state "$status" "$failure_reason")"
  mapped_failure_reason="$(map_terminal_failure_to_reason "$failure_reason")"

  if [[ "${LAST_RUN_EXIT:-0}" != "0" || "${mapped_status}" == "needs-input" ]]; then
    process_failure_strike "$queue_repo" "$issue" "$run_log" "$status"
  fi

  if [[ -n "$brief_id" && -n "${mapped_status}" ]]; then
    terminal_db_ensure
    terminal_state_save \
      "${brief_id}" \
      "${mapped_status}" \
      "${result_kind:-none}" \
      "${pr}" \
      "${actor:-codex}" \
      "${timestamp:-$(date -u +%Y-%m-%dT%H:%M:%SZ)}" \
      "${mapped_failure_reason}" \
      "${queue_repo}#${issue}"
  fi

  if [[ "${mapped_status}" == "blocked" ]]; then
    log "post-verify: ${queue_repo}#${issue} mapped status blocked; reason=${mapped_failure_reason:-none}"
    set_issue_state "$queue_repo" "$issue" "$BLOCKED_LABEL"
    return 0
  fi
  if [[ "${mapped_status}" == "needs-input" ]]; then
    log "post-verify: ${queue_repo}#${issue} reported needs-input"
    set_issue_state "$queue_repo" "$issue" "$NEEDS_INPUT_LABEL"
    return 0
  fi

  if [[ "${mapped_status}" == "stalled" ]]; then
    log "post-verify: ${queue_repo}#${issue} mapped status stalled"
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"
    return 0
  fi

  if [[ "${mapped_status}" == "done" ]]; then
    if [[ "${result_kind}" == "pr" || "${result_kind}" == "comment" || "${result_kind}" == "commit" ]] && \
      [[ "${pr}" != "-" ]]; then
      log "post-verify: ${queue_repo}#${issue} mapped terminal done with result_ref=${pr}"
      set_issue_state "$queue_repo" "$issue" "$DONE_LABEL"
      return 0
    fi
  fi

  local pr_json pr_count pr_number
  pr_json="$(gh pr list --repo "$target_repo" --head "$branch" --state open --json number 2>/dev/null || echo '[]')"
  pr_count="$(jq 'length' <<<"$pr_json" 2>/dev/null || echo 0)"
  pr_number="$(jq -r '.[0].number // empty' <<<"$pr_json" 2>/dev/null || true)"

  if [[ "${pr_count:-0}" -eq 0 ]]; then
    # Read-only/review task gate (Fixes #56, #64):
    # result_kind=comment is the sole authoritative signal that the deliverable IS the
    # review comment (no PR/commit expected). qa=1 (qa_round lines) is NOT sufficient —
    # Codex emits those lines in all report templates including impl tasks (false positive
    # for issue #54). Defense-in-depth: even result_kind=comment must not fire when the
    # worktree has uncommitted or unpushed work; such work always routes to recover_unpublished.
    if [[ "$mapped_status" == "done" && "$result_kind" == "comment" ]] &&        ! worktree_has_work "$repo_path" "$worktree" 2>/dev/null; then
      log "post-verify: ${queue_repo}#${issue} read-only review complete (no PR expected) — done"
      set_issue_state "$queue_repo" "$issue" "$DONE_LABEL"; return 0
    fi
    if worktree_has_work "$repo_path" "$worktree"; then
      recover_unpublished "$queue_repo" "$target_repo" "$issue" "$branch" "$worktree" "$repo_path"; return 0
    fi
    log "post-verify: ${queue_repo}#${issue} produced no PR and no recoverable work — stalled"
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"
    gh issue comment "$issue" --repo "$queue_repo" \
      --body "codex-poll: run finished with no PR/branch and no committed work. Run log: \`${run_log}\`. Marked \`${STALLED_LABEL}\`." >>"$LOG_FILE" 2>&1 || true
    return 0
  fi

  # F6 (#60): guard pr_number before calling gh pr view — empty/null would pass
  # an empty string as the PR number causing a spurious stall.
  if [[ -z "${pr_number:-}" ]]; then
    log "post-verify: ${queue_repo}#${issue} has open PR but could not determine PR number — stalled"
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"; return 0
  fi
  local body
  body="$(gh pr view "$pr_number" --repo "$target_repo" --json body --jq '.body' 2>/dev/null || echo '')"
  if ! grep -q '## PR Packaging' <<<"$body"; then
    log "post-verify: ${queue_repo}#${issue} PR #${pr_number} in ${target_repo} missing ## PR Packaging — stalled"
    gh pr edit "$pr_number" --repo "$target_repo" --add-label "needs-fix/pr-packaging" >>"$LOG_FILE" 2>&1 || true
    set_issue_state "$queue_repo" "$issue" "$STALLED_LABEL"; return 0
  fi

  if [[ "$target_declared" == "1" ]]; then
    local report_repo
    report_repo="$(extract_report_repo_from_log "$run_log")"
    if [[ -n "${report_repo:-}" && "$report_repo" != "$target_repo" ]]; then
      warn_queue_issue "$queue_repo" "$issue" \
        "CODEX REPORT repo ${report_repo} disagrees with declared Target-Repo ${target_repo}; declared metadata remains authoritative for stall detection"
    fi
  fi

  log "post-verify: ${queue_repo}#${issue} PR #${pr_number} published + packaged — done (CI state owned by automation)"
  set_issue_state "$queue_repo" "$issue" "$DONE_LABEL"
}

run_issue_row() {
  local row="$1"
  local sorted_file="${2:-}"
  CLAIM_BRIEF_ID=""

  local repo_path
  local branch
  local short
  local worktree
  local branch_ref
  local active_worktree

  local candidate_repo
  local candidate_issue
  local candidate_created
  local candidate_title
  local candidate_priority
  local target_repo
  local target_repo_path
  local target_short
  local target_declared
  local preflight_issue_body

  candidate_repo="$(jq -r '.repository.nameWithOwner' <<< "$row")"
  candidate_issue="$(jq -r '.number' <<< "$row")"
  candidate_created="$(jq -r '.createdAt // ""' <<< "$row")"
  candidate_title="$(jq -r '.title // ""' <<< "$row")"
  candidate_priority="$(jq -r '.priority // 9' <<< "$row")"

  preflight_issue_body="$(gh issue view "$candidate_issue" --repo "$candidate_repo" --json body --jq '.body' 2>/dev/null || echo "")"
  target_repo="$(extract_target_repo_from_body "$preflight_issue_body")"
  if [[ -n "${target_repo:-}" ]]; then
    target_declared=1
    target_repo_path="$(target_repo_path "$target_repo")"
  else
    target_declared=0
    target_repo="$candidate_repo"
    target_repo_path="$(issue_repo_path "$candidate_repo")"
  fi
  if [[ ! -d "$target_repo_path/.git" ]]; then
    if [[ "$target_declared" == "1" ]]; then
      log "declared Target-Repo ${target_repo} has no local checkout at ${target_repo_path}"
    else
      log_skipped_issue "$candidate_repo" "$candidate_issue" "missing local checkout at ${target_repo_path}"
    fi
    return 1
  fi
  if [[ -n "$(git -C "$target_repo_path" status --porcelain)" ]]; then
    if [[ "$target_declared" == "1" ]]; then
      log_skipped_issue "$candidate_repo" "$candidate_issue" "dirty target checkout at ${target_repo_path}"
    else
      log_skipped_issue "$candidate_repo" "$candidate_issue" "dirty local checkout at ${target_repo_path}"
    fi
    return 1
  fi

  if ! claim_issue "$candidate_repo" "$candidate_issue"; then
    return 1
  fi
  emit_poll_heartbeat "busy" "${candidate_repo}#${candidate_issue}"

  target_repo="$CLAIM_TARGET_REPO"
  target_repo_path="$CLAIM_TARGET_REPO_PATH"
  target_declared="$CLAIM_TARGET_REPO_DECLARED"
  if [[ ! -d "$target_repo_path/.git" ]]; then
    if [[ "$target_declared" == "1" ]]; then
      log "declared Target-Repo ${target_repo} has no local checkout at ${target_repo_path}"
    else
      log_skipped_issue "$candidate_repo" "$candidate_issue" "missing local checkout at ${target_repo_path}"
    fi
    release_claimed_issue "$candidate_repo" "$candidate_issue"
    return 1
  fi
  repo_path="$target_repo_path"
  if [[ -n "$(git -C "$repo_path" status --porcelain)" ]]; then
    if [[ "$target_declared" == "1" ]]; then
      log_skipped_issue "$candidate_repo" "$candidate_issue" "dirty target checkout at ${repo_path}"
    else
      log_skipped_issue "$candidate_repo" "$candidate_issue" "dirty local checkout at ${repo_path}"
    fi
    release_claimed_issue "$candidate_repo" "$candidate_issue"
    return 1
  fi

  short="$(repo_short_name "$candidate_repo")"
  target_short="$(repo_short_name "$target_repo")"
  # Branches keep the queue issue number and queue short-name even when the worktree
  # is rooted in another repo so the spawned branch records which queue item created it.
  branch="agent/codex/issue-${candidate_issue}-${short}"
  worktree="${WORKTREES_ROOT}/${target_short}-issue-${candidate_issue}-$(date +%s)"
  branch_ref="$(default_branch "$repo_path")"

  if git -C "$repo_path" rev-parse --verify "refs/heads/${branch}" >/dev/null 2>&1; then
    active_worktree="$(
      git -C "$repo_path" worktree list --porcelain 2>/dev/null \
        | awk -v ref="refs/heads/${branch}" '
          /^worktree / { path = $2 }
          /^branch / { if ($2 == ref) { print path; exit } }
        '
    )"
    if [[ -n "${active_worktree:-}" ]]; then
      log "branch ${branch} already checked out in ${active_worktree}; reverting ${candidate_repo}#${candidate_issue} to queued and continuing"
      release_claimed_issue "$candidate_repo" "$candidate_issue"
      return 1
    fi
    git -C "$repo_path" branch -D "$branch" >>"$LOG_FILE" 2>&1 || true
  fi

  if ! git -C "$repo_path" worktree add "$worktree" -b "$branch" "${REMOTE_NAME}/${branch_ref}" >>"$LOG_FILE" 2>&1; then
    log "ERROR: failed to create worktree for ${candidate_repo}#${candidate_issue}; reverting labels and continuing"
    release_claimed_issue "$candidate_repo" "$candidate_issue"
    return 1
  fi

  local queue_brief=""
  if [[ -n "$sorted_file" ]]; then
    queue_brief="$(build_queue_brief "$sorted_file" "$candidate_repo" "$candidate_issue" 2>/dev/null || true)"
  fi

  cleanup_repo="$repo_path"
  cleanup_issue="$candidate_issue"
  cleanup_worktree="$worktree"

  log "selected candidate ${candidate_repo}#${candidate_issue} (priority=${candidate_priority}, created=${candidate_created}, title=${candidate_title})"

  if launch_coded_issue "$candidate_repo" "$candidate_issue" "$worktree" "$branch" "$queue_brief" "$target_repo"; then
    log "codex completed for ${candidate_repo}#${candidate_issue}"
  else
    log "ERROR: codex invocation failed for ${candidate_repo}#${candidate_issue}"
  fi

  # Verify the run and apply a terminal label (done/stalled/blocked/needs-input).
  # MUST run before the RETURN trap removes the worktree (recovery needs it). Non-fatal.
  post_run_verify "$candidate_repo" "$target_repo" "$candidate_issue" "$branch" "$worktree" "$repo_path" "${LAST_RUN_LOG:-}" "${CLAIM_BRIEF_ID}" "${target_declared}" \
    || log "WARNING: post_run_verify errored for ${candidate_repo}#${candidate_issue} (non-fatal)"

  return 0
}

run_webhook() {
  mkdir -p "$STATE_DIR" "$WORKTREES_ROOT"
  chmod 700 "$STATE_DIR" "$WORKTREES_ROOT"
  emit_poll_heartbeat "idle"

  if ! validate_cache_path "$CACHE_DIR"; then
    return 1
  fi

  if [[ ! -d "$CACHE_DIR" ]]; then
    log "cache directory missing: $CACHE_DIR"
  fi
  refresh_target_repo_cache
  load_target_repos

  if (( ${#TARGET_REPOS[@]} == 0 )); then
    log "target repo list is empty"
    return 0
  fi

  local staged_event_file
  local cleanup_repo=""
  local cleanup_worktree=""
  local cleanup_issue=""
  staged_event_file="$(consume_webhook_event_file "$EVENT_DIR" "$STATE_DIR")" || {
    log "webhook: no queued events to process"
    return 0
  }

  local staged_event_file_cleanup="$staged_event_file"
  trap 'rm -f "${staged_event_file_cleanup:-}"; \
    if [[ -n "${cleanup_worktree:-}" ]]; then
      remove_worktree "${cleanup_repo:-}" "${cleanup_worktree:-}" "${cleanup_issue:-}"
    fi' RETURN

  process_webhook_event "$staged_event_file"
}

process_webhook_event() {
  local event_file="$1"
  local event_repo
  local event_issue
  local event_id
  local row

  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  event_repo="$(jq -r '.repo // empty' "$event_file" 2>/dev/null || true)"
  event_issue="$(jq -r '.issue // empty' "$event_file" 2>/dev/null || true)"
  event_id="$(jq -r '.delivery_id // empty' "$event_file" 2>/dev/null || true)"

  if [[ -z "$event_repo" || -z "$event_issue" || ! "$event_issue" =~ ^[0-9]+$ ]]; then
    log "webhook: issue=${event_issue} repo=${event_repo} event_id=${event_id} action=flap-discarded ts=${ts}"
    return 1
  fi

  local target_repo=0
  local configured_repo
  for configured_repo in "${TARGET_REPOS[@]}"; do
    if [[ "$configured_repo" == "$event_repo" ]]; then
      target_repo=1
      break
    fi
  done
  if ((target_repo == 0)); then
    log "webhook: issue=${event_issue} repo=${event_repo} event_id=${event_id} action=flap-discarded ts=${ts}"
    return 1
  fi

  row="$(jq -cn --arg repo "$event_repo" --argjson issue "$event_issue" '{repository:{nameWithOwner:$repo}, number:$issue}')"
  if ! run_issue_row "$row"; then
    if [[ "$CLAIM_SKIP_REASON" == "already-in-progress" ]]; then
      log "webhook: issue=${event_issue} repo=${event_repo} event_id=${event_id} action=flap-discarded ts=${ts}"
      return 0
    fi
    log "webhook: issue=${event_issue} repo=${event_repo} event_id=${event_id} action=flap-discarded ts=${ts}"
    return 0
  fi
  log "webhook: issue=${event_issue} repo=${event_repo} event_id=${event_id} action=started ts=${ts}"
  return 0
}

run() {
  mkdir -p "$STATE_DIR" "$WORKTREES_ROOT" "$STRIKE_STATE_DIR"
  chmod 700 "$STATE_DIR" "$WORKTREES_ROOT" "$STRIKE_STATE_DIR"
  emit_poll_heartbeat "idle"

  if ! validate_cache_path "$CACHE_DIR"; then
    return 1
  fi

  if [[ ! -d "$CACHE_DIR" ]]; then
    log "cache directory missing: $CACHE_DIR"
  fi
  refresh_target_repo_cache
  load_target_repos

  if (( ${#TARGET_REPOS[@]} == 0 )); then
    log "target repo list is empty"
    return 0
  fi

  # Leak fix (#60): make accumulated preserved worktrees observable every cycle.
  # Count + warn only — never auto-delete here (see prune-preserved subcommand).
  count_and_warn_preserved_worktrees

  local candidate_file
  local sorted_file
  local cleanup_repo=""
  local cleanup_worktree=""
  local cleanup_issue=""
  local candidate_file_cleanup=""
  local sorted_file_cleanup=""

  candidate_file="$(mktemp)"
  sorted_file="$(mktemp)"
  candidate_file_cleanup="$candidate_file"
  sorted_file_cleanup="$sorted_file"
  trap 'rm -f "${candidate_file_cleanup:-}" "${sorted_file_cleanup:-}"; \
    if [[ -n "${cleanup_worktree:-}" ]]; then
      remove_worktree "${cleanup_repo:-}" "${cleanup_worktree:-}" "${cleanup_issue:-}"
    fi' RETURN

  poll_queued_candidates "$candidate_file"
  if [[ ! -s "$candidate_file" ]]; then
    log "no queued issues found in configured repos"
    return 0
  fi

  sort_candidates "$candidate_file" > "$sorted_file"
  if [[ ! -s "$sorted_file" ]]; then
    log "no eligible queued issues (all were skipped by decision hold or invalid labels)"
    return 0
  fi

  local selected=0
  while IFS= read -r row; do
    [[ -z "$row" ]] && continue
    if run_issue_row "$row" "$sorted_file"; then
      selected=1
      break
    fi
  done < "$sorted_file"

  if ((selected == 0)); then
    log "all queued candidates were skipped (no clean local checkout available)"
    return 0
  fi
}

main() {
  if [[ -f "${CODEX_POLL_DISABLED_FILE:-${HOME}/.codex-poll.disabled}" ]]; then
    log "poll disabled by CODEX_POLL_DISABLED_FILE"
    return 0
  fi

  if ! command -v "$CODEX_BIN" >/dev/null; then
    log "ERROR: codex executable not found: $CODEX_BIN"
    return 1
  fi

  if ! command -v gh >/dev/null; then
    log "ERROR: gh executable required by codex-poll"
    return 1
  fi

  if ! command -v git >/dev/null; then
    log "ERROR: git executable required by codex-poll"
    return 1
  fi

  if ! command -v jq >/dev/null; then
    log "ERROR: jq executable required by codex-poll"
    return 1
  fi

  if ! command -v python3 >/dev/null; then
    log "ERROR: python3 executable required by codex-poll"
    return 1
  fi

  # PID-file locking (POSIX-portable; kill -0 checks process liveness)
  if [[ -f "$LOCK_FILE" ]]; then
    local existing_pid
    existing_pid="$(cat "$LOCK_FILE" 2>/dev/null || true)"
    if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" 2>/dev/null; then
      log "another codex-poll is already running (pid ${existing_pid})"
      return 0
    fi
    log "removing stale lock file (pid ${existing_pid:-unknown} no longer running)"
    rm -f "$LOCK_FILE"
  fi
  # noclobber makes > fail atomically if another process created the file
  # between our stale-check and our write, preventing a TOCTOU race.
  if (set -o noclobber; printf '%s\n' "$$" > "$LOCK_FILE") 2>/dev/null; then
    trap 'rm -f "$LOCK_FILE"' EXIT
  else
    log "another codex-poll acquired the lock concurrently"
    return 0
  fi

  if [[ "${1:-}" == "webhook" ]]; then
    run_webhook
  elif [[ "${1:-}" == "reset" ]]; then
    # F2 (#60): codex-poll reset <repo> <issue> — clears ledger entry so re-queued
    # issue can run again. Also clears any stale 3+ strike buckets.
    local reset_repo="${2:-}" reset_issue="${3:-}"
    if [[ -z "$reset_repo" || -z "$reset_issue" ]]; then
      log "usage: codex-poll reset <repo> <issue>"
      return 1
    fi
    local reset_body reset_brief_id
    reset_body="$(gh issue view "$reset_issue" --repo "$reset_repo" --json body --jq '.body' 2>/dev/null || echo "")"
    reset_brief_id="$(derive_brief_id "$reset_repo" "$reset_issue" "$reset_body")"
    terminal_db_ensure
    terminal_state_clear "$reset_brief_id"
    reset_3plus_issue_strikes "$reset_repo" "$reset_issue" 2>/dev/null || true
    log "reset ledger entry for ${reset_repo}#${reset_issue} (brief_id=${reset_brief_id})"
  elif [[ "${1:-}" == "prune-preserved" ]]; then
    # Leak fix (#60): explicit, operator-initiated cleanup of preserved worktrees that
    # are confirmed safe (branch on origin) AND older than the threshold. Conservative
    # by design — unpushed work is never auto-deleted.
    shift
    prune_preserved "$@"
  else
    run
  fi
}

issue_state_from_labels() {
  local labels="$1"
  if printf '%s\n' "$labels" | grep -Fxq "$BLOCKED_LABEL"; then
    echo "blocked"
    return 0
  fi
  if printf '%s\n' "$labels" | grep -Fxq "$NEEDS_INPUT_LABEL"; then
    echo "needs-input"
    return 0
  fi
  if printf '%s\n' "$labels" | grep -Fxq "$STALLED_LABEL"; then
    echo "stalled"
    return 0
  fi
  if printf '%s\n' "$labels" | grep -Fxq "$DONE_LABEL"; then
    echo "done"
    return 0
  fi
  if printf '%s\n' "$labels" | grep -Fxq "$WORKING_LABEL"; then
    echo "processing"
    return 0
  fi
  if printf '%s\n' "$labels" | grep -Fxq "$QUEUE_LABEL"; then
    echo "queued"
    return 0
  fi
  echo "unknown"
}

is_valid_transition() {
  local from="$1"
  local to="$2"
  case "${from}:${to}" in
    queued:processing|unknown:processing|blocked:processing|needs-input:processing|stalled:processing)
      return 0
      ;;
    processing:done|processing:blocked|processing:needs-input|processing:stalled)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

extract_brief_id_from_body() {
  local body="$1"
  python3 - "$body" <<'PY'
import re
import sys

body = sys.argv[1]
patterns = [
    r'"brief_id"\s*:\s*"([^"]+)"',
    r'\bbrief_id\s*[:=]\s*([\w.-]+)',
    r'\bbid\s*[:=]\s*([\w.-]+)',
    r'\bbrief\s+id\s*[:=]\s*([\w.-]+)',
]

for pattern in patterns:
    match = re.search(pattern, body, re.IGNORECASE)
    if match:
        print(match.group(1).strip())
        raise SystemExit(0)

print("")
PY
}

derive_brief_id() {
  local repo="$1"
  local issue="$2"
  local body="${3:-}"
  local explicit_brief_id
  local body_id
  explicit_brief_id="$(extract_brief_id_from_body "$body")"
  if [[ -n "${explicit_brief_id}" ]]; then
    echo "${explicit_brief_id}"
    return 0
  fi

  if [[ -n "${CODEX_POLL_BRIEF_ID:-}" ]]; then
    echo "${CODEX_POLL_BRIEF_ID}"
    return 0
  fi
  if [[ -n "$body" ]]; then
    body_id="$(printf '%s' "$body" | sha256sum | awk '{print $1}')"
    echo "${repo}#${issue}:${body_id}"
    return 0
  fi
  echo "${repo}#${issue}"
}

terminal_db_ensure() {
  mkdir -p "$STATE_DIR"
  if [[ ! -f "$TERMINAL_STATE_FILE" ]]; then
    printf '%s\n' "{}" > "$TERMINAL_STATE_FILE"
  fi
}

terminal_state_is_processed() {
  local brief_id="$1"
  local status
  if [[ -z "${brief_id:-}" ]]; then
    return 1
  fi
  if [[ ! -f "$TERMINAL_STATE_FILE" ]]; then
    return 1
  fi
  status="$(jq -r --arg id "$brief_id" '.[$id].status // empty' "$TERMINAL_STATE_FILE" 2>/dev/null || true)"
  case "$status" in
    done|blocked|needs-input|stalled|failed)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

terminal_state_clear() {
  local brief_id="$1"
  [[ -n "$brief_id" ]] || return 0
  terminal_db_ensure
  python3 - "$TERMINAL_STATE_FILE" "$brief_id" <<'PY'
import json
import sys

path, brief_id = sys.argv[1], sys.argv[2]
try:
    with open(path, "r", encoding="utf-8") as fh:
        data = json.load(fh)
except Exception:
    data = {}
if not isinstance(data, dict):
    data = {}
data.pop(brief_id, None)
with open(path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, sort_keys=True)
PY
}

terminal_state_save() {
  local brief_id="$1"
  local status="$2"
  local result_kind="$3"
  local result_ref="$4"
  local actor="$5"
  local timestamp="$6"
  local failure_reason="$7"
  local issue_ref="${8:-}"

  [[ -n "$brief_id" ]] || return 0
  [[ -n "${status}" ]] || return 0
  terminal_db_ensure

  python3 - "$TERMINAL_STATE_FILE" "$brief_id" "$status" "$result_kind" "$result_ref" "$actor" "$timestamp" "$failure_reason" "$issue_ref" <<'PY'
import json
import sys

path, brief_id, status, result_kind, result_ref, actor, timestamp, failure_reason, issue_ref = sys.argv[1:10]
data = {}
try:
    with open(path, "r", encoding="utf-8") as fh:
        data = json.load(fh)
except Exception:
    data = {}
if not isinstance(data, dict):
    data = {}

data[brief_id] = {
    "status": status,
    "result_kind": result_kind,
    "result_ref": result_ref,
    "actor": actor,
    "timestamp": timestamp,
}
if failure_reason:
    data[brief_id]["failure_reason"] = failure_reason
if issue_ref:
    data[brief_id]["issue_ref"] = issue_ref

with open(path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, sort_keys=True)
PY
}

map_terminal_outcome_to_state() {
  local status="$1"
  local failure_reason="$2"
  failure_reason="$(printf '%s' "$failure_reason" | tr '[:upper:]' '[:lower:]')"
  case "$status" in
    "")
      echo ""
      return 0
      ;;
    done)
      echo "done"
      return 0
      ;;
    failed)
      case "$failure_reason" in
        refusal|capacity_unavailable)
          echo "blocked"
          return 0
          ;;
        *)
          echo "stalled"
          return 0
          ;;
      esac
      ;;
    blocked)
      echo "blocked"
      return 0
      ;;
    stalled)
      echo "stalled"
      return 0
      ;;
    needs-input)
      echo "needs-input"
      return 0
      ;;
    processing|in-progress|queued|unknown)
      echo "processing"
      return 0
      ;;
    *)
      echo "stalled"
      return 0
      ;;
  esac
}

map_terminal_failure_to_reason() {
  local reason="$1"
  reason="$(printf '%s' "$reason" | tr '[:upper:]' '[:lower:]')"
  case "$reason" in
    refusal|refused|model_refusal|model_refused)
      echo "refusal"
      return 0
      ;;
    capacity_unavailable|throttled|throttle|rate_limited|rate-limit|gated|gated_access|capacity)
      echo "capacity_unavailable"
      return 0
      ;;
    dirty_checkout|worktree_create_failed|sandbox_denied|build_failed|test_failed|lint_failed|rebase_conflict|capability_mismatch|timeout|malformed_brief|unknown)
      echo "$reason"
      return 0
      ;;
    "")
      echo ""
      return 0
      ;;
    *)
      echo "unknown"
      return 0
      ;;
  esac
}

main "$@"
